# CI-TEC Knowledge Platform — copy to .env and fill values
#   cp .env.example .env
#
# Dev server: OpenRouter → GLM (same profile as prod Fabrix when possible)
# Prod (air-gap): COMPANY_* Fabrix vars or internal OpenAI-compatible base URL

# --- LLM (dev: OpenRouter) ---
OPENROUTER_API_KEY=sk-or-...
# config/models.json key (dev). Prod may use Fabrix UUID + COMPANY_MODEL_PROFILE=glm-5.2
COMPANY_MODEL_ID=glm-5.2
# COMPANY_MODEL_PROFILE=glm-5.2

# Optional: override OpenRouter base (default https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- LLM (prod Fabrix — optional, takes precedence when all set) ---
# COMPANY_ENDPOINT_URL=
# COMPANY_CLIENT_KEY=
# COMPANY_PASS_KEY=
# COMPANY_EMAIL=

# --- App ---
APP_ENV=dev
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# --- Postgres ---
POSTGRES_USER=citec
POSTGRES_PASSWORD=citec
POSTGRES_DB=citec_knowledge
DATABASE_URL=postgresql+psycopg://citec:citec@postgres:5432/citec_knowledge

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Paths (compose mounts) ---
RAW_DIR=/data/raw
# Host path for corpus (default: ./data/raw in compose)
# RAW_HOST_DIR=./data/raw

# Host port map is fixed in docker-compose.yml within 8572–8580:
#   web 8572 · api 8573 · postgres 8574 · redis 8575
