# CI-TEC Knowledge Platform — copy to .env and fill values
#   cp .env.example .env
#
# Dev server: OpenRouter → GLM (same profile as prod Fabrix when possible)
# Prod (air-gap): COMPANY_* Fabrix vars or internal OpenAI-compatible base URL

# --- LLM (dev: OpenRouter) ---
OPENROUTER_API_KEY=sk-or-...
# config/models.json key (dev). Prod may use Fabrix UUID + COMPANY_MODEL_PROFILE=glm-5.2
COMPANY_MODEL_ID=glm-5.2
# COMPANY_MODEL_PROFILE=glm-5.2

# Optional: override OpenRouter base (default https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- LLM (prod Fabrix — optional, takes precedence when all set) ---
# COMPANY_ENDPOINT_URL=
# COMPANY_CLIENT_KEY=
# COMPANY_PASS_KEY=
# COMPANY_EMAIL=

# --- App ---
APP_ENV=dev
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# --- Auth / SSO (default off = open pilot) ---
# AUTH_MODE: off | apikey | oidc_stub | oidc
AUTH_MODE=off
# Optional inline tokens JSON (else config/auth.json sample tokens)
# AUTH_TOKENS_JSON={"dev-admin":{"sub":"a1","name":"Admin","roles":["viewer","author","senior","admin"]}}
# OIDC (Keycloak / Entra / Okta …)
# OIDC_ISSUER=https://login.example.com/realms/citec
# OIDC_CLIENT_ID=citec-kb
# OIDC_CLIENT_SECRET=
# OIDC_AUDIENCE=citec-kb
# OIDC_REDIRECT_URI=http://localhost:8573/v1/auth/callback
# OIDC_SCOPES=openid profile email
# OIDC_ROLE_CLAIM=roles
# Local HS256 JWT (dev mint via POST /v1/auth/dev/token) — no external IdP needed
# OIDC_JWT_SECRET=change-me-dev-only
# PUBLIC_WEB_BASE=http://localhost:8572
# PUBLIC_API_BASE=http://localhost:8573
#
# Built-in mock IdP (RS256 JWKS) for local e2e — see docs/OIDC_IDP_SETUP.md
# MOCK_OIDC_ENABLED=true
# OIDC_ISSUER=http://localhost:8573/v1/mock-idp
# OIDC_CLIENT_ID=citec-kb
# OIDC_CLIENT_SECRET=mock-secret


# --- Postgres ---
POSTGRES_USER=citec
POSTGRES_PASSWORD=citec
POSTGRES_DB=citec_knowledge
DATABASE_URL=postgresql+psycopg://citec:citec@postgres:5432/citec_knowledge

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Paths (compose mounts) ---
RAW_DIR=/data/raw
# Host path for corpus (default: ./data/raw in compose)
# RAW_HOST_DIR=./data/raw

# Host port map is fixed in docker-compose.yml within 8572–8580:
#   web 8572 · api 8573 · postgres 8574 · redis 8575
